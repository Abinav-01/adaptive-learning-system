# Example environment variables for Adaptive Learning System
# Copy to .env and fill in real values (DO NOT commit .env with secrets)

# Aipipe API Key for centralized LLM services (Lessons & Tutor)
AIPIPE_API_KEY=your_aipipe_api_key_here

SECRET_KEY=change_this_secret_key_for_production
DATABASE_URL=sqlite:///./app.db
